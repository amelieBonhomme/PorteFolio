                    </div>

                    <div class="form-row">
                        <p>{{ form_label(IPForm.description, 'Description :') }}</p>
                        <p>{{ form_widget(IPForm.description, {'attr': {'class': 'form-input'}}) }}</p>
                    </div>

                    <div class="form-row">
                        <p>{{ form_label(IPForm.mail, 'Mail :') }}</p>
                        <p>{{ form_widget(IPForm.mail, {'attr': {'class': 'form-input'}}) }}</p>
                    </div>

                    <div class="form-row">
                        <p>{{ form_label(IPForm.telephone, 'Téléphone :') }}</p>
                        <p>{{ form_widget(IPForm.telephone, {'attr': {'class': 'form-input'}}) }}</p>
                    </div>

                    <div class="form-row">
                        <p>{{ form_label(IPForm.localisationMap, 'Adresse localisation Google Maps :') }}</p>
                        <p>
                            {{ form_widget(IPForm.localisationMap, {'attr': {'class': 'form-input'}}) }}
                            <span class="help-icon" aria-label="Informations sur ce champ"> 
                                ? 
                                <span class="help-tooltip">Liens de localisation exact (donner votre ville en ChatGPT et il le génèrera)</span> 
                            </span>
                        </p>
                    </div>

                    <div class="form-row">
                        <p>{{ form_label(IPForm.linkedin, 'Lien LinkedIn :') }}</p>
                        <p>{{ form_widget(IPForm.linkedin, {'attr': {'class': 'form-input'}}) }}</p>
                    </div>

                    <div class="form-row">
                        <p>{{ form_label(IPForm.images, 'Images centre d’intérêt (4 max) :') }}</p>
                        <p>
                            {{ form_widget(IPForm.images, {'attr': {'class': 'form-input', 'multiple': 'multiple'}}) }}
                            <span class="help-icon" aria-label="Informations sur ce champ"> 
                                ? 
                                <span class="help-tooltip">Maximum 4 images et leur tailles doit être de maximum 1mo chacune</span> 
                            </span>
                        </p>
                    </div>

                    <div class="images-centre-interet">
                        {% if centreInterets %}
                            {% for interet in centreInterets %}
                                <img src="{{ interet.image }}" alt="Centre d’intérêt" class="img-centre-interet">
                            {% endfor %}
                        {% endif %}
                    </div>

                    <div class="form-row">
                        <p>{{ form_label(IPForm.centreInteretTexte, 'Texte centre d’intérêt (séparé par des point virgules) :') }}</p>
                        <p>
                            {{ form_widget(IPForm.centreInteretTexte, {'attr': {'class': 'form-input'}}) }}
                            <span class="help-icon" aria-label="Informations sur ce champ"> 
                                ? 
                                <span class="help-tooltip">Les titres doivent être dans le même ordre que les images et séparés par des points virgules</span> 
                            </span>
                        </p>
                    </div>

                    <div class="form-row">
                        <p>{{ form_label(IPForm.metier, 'Métier :') }}</p>
                        <p>{{ form_widget(IPForm.metier, {'attr': {'class': 'form-input'}}) }}</p>
                    </div>

                    <div class="form-row">
                        <p>{{ form_label(IPForm.photo, 'Photo de profil :') }}</p>
                        <p>
                            {{ form_widget(IPForm.photo, {'attr': {'class': 'form-input'}}) }}
                            <span class="help-icon" aria-label="Informations sur ce champ"> 
                                ? 
                                <span class="help-tooltip">Une seule photo attendu maximum 1mo</span> 
                            </span>
                        </p>
                    </div>

                    {% if photo %}
                        <img class="img-centre-interet" src="{{ photo }}" alt="Portrait">
                    {% endif %} 
                </div>

            {% endif %}
            <button type="submit" class="form-button boutonform" style="background-color: {{ couleurNavigation }}; color: {{ couleurTexteNavigation }};">
                Enregistrer
            </button>
        {{ form_end(IPForm) }}


