                            <span class="help-icon" aria-label="Informations sur ce champ"> 
                                ? 
                                <span class="help-tooltip">Renseinger les documents dans le même ordre que les titres.</span> 
                            </span>
                        </p>

                        <div class="pdf-list">
                            {% if Grouppdf %}
                                {% for doc in Grouppdf %}
                                    <div class="pdf-preview">
                                        <a href="{{ doc.file }}" target="_blank" download="document.pdf" class="pdf-link">
                                            📄 {{ doc.titre }}
                                        </a>

                                    </div>
                                {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                </div>

            {% else %}

                <div class="FormMobile">

                    <div class="form-row">
                        <p>{{ form_label(ProjetForm.titreProjet, 'Nom du projet :') }}</p>
                        <p>
                            {{ form_widget(ProjetForm.titreProjet, {'attr': {'class': 'form-input'}}) }}
                            <span class="help-icon" aria-label="Informations sur ce champ"> 
                                ? 
                                <span class="help-tooltip">Renseigner les titres des 2 projets séparer par des points virgules.</span> 
                            </span>
                        </p>
                    </div>

                    <div class="form-row">
                        <p>{{ form_label(ProjetForm.documents, 'Documents PDF du projet (2 max) :') }}</p>
                        <p>
                            {{ form_widget(ProjetForm.documents, {'attr': {'class': 'form-input', 'multiple': 'multiple'}}) }}
                            <span class="help-icon" aria-label="Informations sur ce champ"> 
                                ? 
                                <span class="help-tooltip">Renseinger les documents dans le même ordre que les titres.</span> 
                            </span>
                        </p>
                    </div>

                    <div class="pdf-list">
                        {% if Grouppdf %}
                            {% for doc in Grouppdf %}
                                <div class="pdf-preview">
                                    <a href="{{ doc.file }}" target="_blank" download="document.pdf" class="pdf-link">
                                        📄 {{ doc.titre }}
                                    </a>
                                </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>

            {% endif %}
            <button type="submit" class="form-button boutonform" style="background-color: {{ couleurNavigation }}; color: {{ couleurTexteNavigation }};">
                Enregistrer
            </button>
        {{ form_end(ProjetForm) }}

        <h1>Login</h1>

        {{ form_start(PAForm) }}
            {% if not isMobile %}
                <div class="Form">
                    <div class="FormText1">
                        <p>{{ form_label(PAForm.login, 'Login :') }}</p>
                        <p>{{ form_label(PAForm.plainPassword, 'Nouveau mot de passe :') }}</p>
                    </div>

                    <div class="FormInput">
                        <p>{{ form_widget(PAForm.login, {'attr': {'class': 'form-input'}}) }}</p>
                        <p>{{ form_widget(PAForm.plainPassword, {'attr': {'class': 'form-input'}}) }}</p>
                    </div>
                </div>
            {% else %}
                <div class="FormMobile">

                    <div class="form-row">
                        <p>{{ form_label(PAForm.login, 'Login :') }}</p>
                        <p>{{ form_widget(PAForm.login, {'attr': {'class': 'form-input'}}) }}</p>
                    </div>

                    <div class="form-row">
                        <p>{{ form_label(PAForm.plainPassword, 'Nouveau mot de passe :') }}</p>
                        <p>{{ form_widget(PAForm.plainPassword, {'attr': {'class': 'form-input'}}) }}</p>
                    </div>

                </div>
            {% endif %}
            <button type="submit" class="form-button boutonform" style="background-color: {{ couleurNavigation }}; color: {{ couleurTexteNavigation }};">
                Enregistrer
            </button>
        {{ form_end(PAForm) }}

        
        <div class="logout-container">
            <a href="{{ path('logout') }}" class="form-button boutonform" style="background-color: {{ couleurNavigation }}; color: {{ couleurTexteNavigation }};">
                Déconnexion
            </a>
        </div>

    </section>
</section>
{% endblock %}

