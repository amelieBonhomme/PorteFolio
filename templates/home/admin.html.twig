                                ? 
                                <span class="help-tooltip">Couleur du texte de motivation et footer en Hexadéciaml : #fffff ou RGB : rgb(255, 255, 255, 0.651)</span> 
                            </span>
                        </p>
                    </div>

                    <div class="form-row">
                        <p>{{ form_label(designForm.couleurNavigation, 'Couleur barre navigation :') }}</p>
                        <p>
                            {{ form_widget(designForm.couleurNavigation, {'attr': {'class': 'form-input'}}) }}
                            <span class="help-icon" aria-label="Informations sur ce champ"> 
                                ? 
                                <span class="help-tooltip">Couleur de la barre de navigation et des boutons en Hexadéciaml : #fffff ou RGB : rgb(255, 255, 255, 0.651)</span> 
                            </span>
                        </p>
                    </div>

                    <div class="form-row">
                        <p>{{ form_label(designForm.couleurTexteNavigation, 'Couleur texte barre navigation :') }}</p>
                        <p>
                            {{ form_widget(designForm.couleurTexteNavigation, {'attr': {'class': 'form-input'}}) }}
                            <span class="help-icon" aria-label="Informations sur ce champ"> 
                                ? 
                                <span class="help-tooltip">Couleur du texte de la barre de naigation et des boutons en Hexadéciaml : #fffff ou RGB : rgb(255, 255, 255, 0.651)</span> 
                            </span>
