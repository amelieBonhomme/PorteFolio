<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <script src="{{ asset('js/ecriturePrenom.js') }}"></script>

        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('css/style.css') }}">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>

    <body>
        {% block navbar %}
        <nav class="navbar">
            <ul>
                <li><a href="{{ path('home') }}">Accueil</a></li>
                <li><a href="#partie1">Présentation</a></li>
                <li><a href="#entreprise">Expérience</a></li>
                <li><a href="#competence">Compétences</a></li>
                <li><a href="#projet">Projet</a></li>
                <li><a href="{{ path('veille') }}">Veille technologique</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </nav>
        {% endblock %}
        {% block body %}{% endblock %}

        {% block footer %}
        <footer id="contact">
            <div class="contactener">
                <h1>Contacts :</h1>
                <div class="pdf">
                    <div>
                        <h2>Ma localisation</h2>
                        <iframe class="mapgg" src="https://www.google.com/maps/embed?..."></iframe>
                    </div>
                    <div class="info">
                        <h3>Linkedin <a href="mailto:amelie@example.com">..........................</a></h3>
                        <h3>Email : <a href="mailto:amelie@example.com">amelie@example.com</a></h3>
                    </div>
                </div>
            </div>
        </footer>
        {% endblock %}
    </body>

</html>
