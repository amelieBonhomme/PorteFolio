<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Bienvenu dans mon portefolio{% endblock %}</title>
        <link rel="icon" href="{{ asset('favicon.ico') }}">
        <script src="{{ asset('js/ecriturePrenom.js') }}"></script>
        <meta name="viewport" content="width=device-width, initial-scale=1.0">  

        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('css/style.css') }}">
        {% endblock %}

        {% block javascripts %}
            <script src="{{ asset('js/detectAdmin.js') }}"></script>
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>

    <body style="background-color: {{ couleurFond }}; color: {{ couleurTexte }};">
        {% block navbar %}
        <nav class="navbar" style="background-color: {{ couleurNavigation }};">
            <ul>
                <li><a style=" color: {{ couleurTexteNavigation }};" href="{{ path('home') }}">Accueil</a></li>
                <li><a style=" color: {{ couleurTexteNavigation }};" href="#partie1">Présentation</a></li>
                <li><a style=" color: {{ couleurTexteNavigation }};" href="#entreprise">Expérience</a></li>
                <li><a style=" color: {{ couleurTexteNavigation }};" href="#competence">Compétences</a></li>
                <li><a style=" color: {{ couleurTexteNavigation }};" href="#projet">Projet</a></li>
                <li><a style=" color: {{ couleurTexteNavigation }};" href="{{ path('veille') }}">Veille technologique</a></li>
                <li><a style=" color: {{ couleurTexteNavigation }};" href="#contact">Contact</a></li>
            </ul>   
        </nav>
        {% endblock %}
        {% block body %}{% endblock %}

        {% block footer %}
        <footer id="contact" style="background-color: {{ couleurMotivationFooter }}; color: {{ couleurTexteMotivationFooter }};">
            <div class="contactener">
                <h1 class = "titrefooter">Contacts :</h1>
                <div class="pdf">
                    <div>
                        <iframe class="mapgg" src="{{localisationMap}}" title="localisation"></iframe>
                    </div>
                    <div class="info">
                        <h3>Linkedin :<a href="{{linkedin}}">Mon profil</a></h3>
                        <h3>Email : <a href="mailto:{{mail}}">{{mail}}</a></h3>
                        <h3>Tel : {{tel}}</h3>
                    </div>
                    <div class="info2">
                        <h3>Mention légale :<a href="{{ path('mentions_legales') }}">Consulter</a></h3>
                        <h3>Condition d'utilisation :<a href="{{ path('condition_utilisation') }}">Consulter</a></h3>
                    </div>
                </div>
            </div>
        </footer>
        {% endblock %}
    </body>

</html>
