{% extends 'base.html.twig' %}

{% block title %}Connexion Admin{% endblock %}
{% block javascripts %}
    <script src="{{ asset('js/zoom.js') }}"></script>
{% endblock %}

{% block body %}
    <section id="loginpage">
        <div id="loginAdmin">
            <h1>Connexion</h1>

            {% if error %}
                <div class="form-error">{{ error }}</div>
            {% endif %}

            {{ form_start(form, {'attr': {'class': 'login-form'}}) }}
                <div class="form-group">
                    {{ form_label(form.login, 'Login :') }}
                    {{ form_widget(form.login, {'attr': {'class': 'form-input'}}) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.mdp, 'Mot de passe :') }}
                    {{ form_widget(form.mdp, {'attr': {'class': 'form-input'}}) }}
                </div>
                <button type="submit" class="form-button" style="background-color: {{ couleurNavigation }};">
                    Se connecter
                </button>
            {{ form_end(form) }}
        </div>
    </section>
{% endblock %}

{% block footer %}{% endblock %}
